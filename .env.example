APP_ENV=local
APP_VERSION=0.1.0
API_PORT=8000
FRONTEND_PORT=3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/reports
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

SQS_QUEUE_URL=http://localstack:4566/000000000000/reports-jobs-standard
SQS_STANDARD_QUEUE_URL=http://localstack:4566/000000000000/reports-jobs-standard
SQS_HIGH_PRIORITY_QUEUE_URL=http://localstack:4566/000000000000/reports-jobs-high
SQS_DLQ_URL=http://localstack:4566/000000000000/reports-jobs-dlq
S3_REPORTS_BUCKET=reports-results
S3_RESULT_BASE_URL=http://localhost:4566/reports-results
CLOUDWATCH_NAMESPACE=ReportsPlatform

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WORKER_CONCURRENCY=2
WORKER_POLL_SECONDS=20
WORKER_MAX_RECEIVE_COUNT=3
WORKER_SLEEP_MIN_SECONDS=5
WORKER_SLEEP_MAX_SECONDS=30
WORKER_CIRCUIT_BREAKER_THRESHOLD=3
WORKER_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=120
WEBSOCKET_POLL_INTERVAL_SECONDS=2
HIGH_PRIORITY_REPORT_TYPES=fraud_alert,security_incident,executive_summary
